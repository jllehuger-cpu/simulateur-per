{
  "name": "simulateur-patrimoine",
  "version": "1.0.0",
  "description": "Simulateurs patrimoine : Assurance-vie, IR, PER, Succession",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:unit": "ts-node test-suite.ts",
    "test:api": "ts-node test-api.ts",
    "test:api:watch": "nodemon --exec 'ts-node test-api.ts'",
    "test:all": "npm run test:unit && npm run test:api",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:debug": "playwright test --debug",
    "test:validate": "npm run type-check && npm run lint && npm run test:unit",
    "test:ci": "npm run type-check && npm run lint && npm run test:coverage && npm run test:api",
    "docs:serve": "npx markdown-preview docs/*.md",
    "gen:report": "ts-node scripts/generate-test-report.ts",
    "precommit": "npm run test:validate",
    "prepush": "npm run test:ci"
  },
  "dependencies": {
    "next": "^15.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^14.1.0",
    "@types/jest": "^29.5.5",
    "@types/node": "^20.9.0",
    "eslint": "^8.53.0",
    "eslint-config-next": "^14.0.0",
    "node-fetch": "^3.3.2",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "vitest": "^0.34.6"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
